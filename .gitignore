# Data files (large, download from HuggingFace)
data/*.csv

# Experiment outputs (generated by run.py)
results/*.npy
# Note: results/*.png is tracked (for README figure)

# Rendered reports (regenerate from notebooks)
outputs/*.html

# Python
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# macOS
.DS_Store

# IDE
.vscode/
.idea/

# PDFs (except reference paper and README export)
# *.pdf is not blanket-ignored; specific PDFs are tracked
